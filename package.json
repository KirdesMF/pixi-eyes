{
  "name": "pixi-eyes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "bun run build && wrangler dev",
    "check": "tsc --noEmit",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint src vite.config.ts --deny-warnings",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "pixi.js": "^8.17.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.3",
    "@tailwindcss/vite": "^4.2.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wrangler": "^4.79.0"
  }
}
